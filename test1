local Players = game:GetService("Players")
local player = Players.LocalPlayer
local selectedPlayer = nil
local highSpawn = nil
-- Criar ScreenGui
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false

local ativo = false

-- Frame principal
local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 300, 0, 400)
frame.Position = UDim2.new(0.5, -150, 0.5, -200)
frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
frame.Active = true
frame.Draggable = true

-- Botão ativar/desativar
local toggle = Instance.new("TextButton", frame)
toggle.Size = UDim2.new(1, 0, 0, 40)
toggle.Text = "desativado"
toggle.BackgroundColor3 = Color3.fromRGB(50,50,50)

local function iniciar2()
    task.spawn(function ()
        while ativo do
            local spawns = game.Workspace.Markers.teleporters
            local infinite = math.huge
            for _, spawnLoc in pairs(spawns:GetChildren()) do
                if spawnLoc.Position.Y < infinite then
                    infinite = spawnLoc.Position.Y
                    highSpawn = spawnLoc
                    print(spawnLoc)
                end
            end
            print(spawns)
            wait(15)
        end
    end)

    task.spawn(function()
        while ativo do
            local args = {
                [1] = true,
                [2] = 1771796869.978353
            }
            game:GetService("ReplicatedStorage").Remotes.game.action.mouse1:FireServer(unpack(args))
            wait(0.5)
        end
    end)
end

local function iniciar()
    task.spawn(function ()
        while ativo do
            local livePlaayer = game.Workspace.Living
            for _, plive in pairs(livePlaayer:GetChildren()) do 
                if selectedPlayer.Name == plive.Name then
                    game:GetService("ReplicatedStorage").Remotes.game.deploy:InvokeServer()
                end
            end
            wait(3)
        end
    end)

    task.spawn(function ()
        while ativo do
            if selectedPlayer and selectedPlayer.Character and selectedPlayer.Character:FindFirstChild("HumanoidRootPart") and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                player.Character.HumanoidRootPart.CFrame = selectedPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,1)
            end
            wait(0.01)
        end
    end)
end

toggle.MouseButton1Click:Connect(function()
    ativo = not ativo
    if ativo then
        iniciar()
        iniciar2()
    end
    toggle.Text = ativo and "Ativado" or "Desativado"
end)

-- Lista de jogadores
local scrolling = Instance.new("ScrollingFrame", frame)
scrolling.Position = UDim2.new(0, 0, 0, 50)
scrolling.Size = UDim2.new(1, 0, 1, -50)
scrolling.CanvasSize = UDim2.new(0,0,0,0)
scrolling.ScrollBarThickness = 6

local layout = Instance.new("UIListLayout", scrolling)

local selectedLabel = Instance.new("TextLabel", frame)
selectedLabel.Size = UDim2.new(1, 0, 0, 30)
selectedLabel.Position = UDim2.new(0, 0, 1, -30)
selectedLabel.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
selectedLabel.Text = "Nenhum selecionado"

local function atualizarLista()
    for _, child in pairs(scrolling:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end

    for _, plr in pairs(Players:GetPlayers()) do
        local button = Instance.new("TextButton", scrolling)
        button.Size = UDim2.new(1, -5, 0, 30)
        button.Text = plr.Name
        button.BackgroundColor3 = Color3.fromRGB(204, 255, 255)
        
        button.MouseButton1Click:Connect(function()
            selectedPlayer = plr
            selectedLabel.Text = selectedPlayer.Name
        end)
    end
    
    task.wait()
    scrolling.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y)
end

local closeButton = Instance.new("TextButton", frame)
closeButton.Size = UDim2.new(0, 30, 0, 30)
closeButton.Position = UDim2.new(1, -35, 0, 5)
closeButton.Text = "X"
closeButton.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)

closeButton.MouseButton1Click:Connect(function()
    ativo = false
    gui:Destroy()
end)

Players.PlayerAdded:Connect(atualizarLista)
Players.PlayerRemoving:Connect(atualizarLista)

atualizarLista()
